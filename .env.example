# --- Vite (browser) — same as Supabase dashboard → API ---
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optional: force REST API in dev (default: off in dev, on in production build)
# VITE_USE_VERCEL_API=true

# Optional: external API origin (e.g. https://api.example.com). Leave unset on Vercel same-origin.
# VITE_API_BASE_URL=

# Local dev only: proxy /api to Vercel serverless while `npm run dev` (set when `npx vercel dev --listen 3000` is running)
# VITE_DEV_PROXY_API=http://127.0.0.1:3000

# --- Vercel serverless (Dashboard → Environment Variables, not VITE_*) ---
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Recommended if you call /api/cron/settle-bets (manual, scheduled job, or Vercel Cron on a paid plan):
# CRON_SECRET=generate-a-long-random-string
# Send header: Authorization: Bearer <CRON_SECRET> or x-cron-secret: <CRON_SECRET>

# Razorpay (get from https://dashboard.razorpay.com → Settings → API Keys)
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXX
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
